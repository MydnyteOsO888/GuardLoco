# ── App ───────────────────────────────────────────────────
APP_NAME=CarGuard API
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# ── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://carguard:password@localhost:5432/carguard_db
DATABASE_URL_SYNC=postgresql://carguard:password@localhost:5432/carguard_db

# ── JWT Auth ──────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Firebase Admin (FCM Push Notifications) ───────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── AWS S3 (Cloud Video Storage) ─────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=carguard-video-storage
AWS_S3_PRESIGNED_URL_EXPIRY=3600

# ── ESP32 Device ──────────────────────────────────────────
ESP32_IP=192.168.137.209
ESP32_PORT=80
ESP32_STREAM_PORT=81
ESP32_API_KEY=dev-esp32-key

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Storage Settings ──────────────────────────────────────
MAX_CLIP_DURATION_SECONDS=60
AUTO_DELETE_CLIPS_AFTER_DAYS=7
MAX_LOCAL_STORAGE_GB=20
